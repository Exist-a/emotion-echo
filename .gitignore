# ============================================================
# Emotion-Echo monorepo · .gitignore
# ============================================================
# 主仓根目录 .gitignore，覆盖根级 + 所有 Go/Node/Python 子项目
# 子模块目录（Emotion-Echo-Web / legacy/emotion-echo-gin /
# Emotion-Echo-LLM/sensevoice-small / Emotion-Echo-LLM/XTTS/TTS）
# 各自保留自己的 .git，本文件对它们**不再生效**（它们是独立仓）。

# ---------- 通用 ----------
.DS_Store
Thumbs.db
desktop.ini
*.log
*.tmp
*.swp
*.swo
*~
.idea/
.vscode/
.trae/
.cursor/
*.iml

# ---------- Go ----------
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/
coverage.txt
coverage.html
*.coverprofile
# Go 编译产物（无后缀的可执行文件）
/legacy/emotion-echo-gin/server
/server
/bin/

# ---------- Node / Nuxt ----------
node_modules/
.nuxt/
.output/
.cache/
.next/
.parcel-cache/
dist/
build/
*.tsbuildinfo

# ---------- 资源/模型文件（二进制，体积大，运行时按需下载） ----------
*.vrm
*.gltf
*.glb
*.fbx
*.obj
*.ttf
*.woff
*.woff2
*.eot

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.eggs/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.tox/
venv/
.venv/
env/
ENV/

# ---------- 运行时数据 / 数据库 ----------
.postgres/
*.db
*.sqlite
*.sqlite3
pg_log.txt

# ---------- 散落的 proto 生成物（P1-D 规范化前的临时方案） ----------
/*.pb.go
/*_grpc.pb.go

# ---------- AI 模型权重（体积过大，禁止入仓） ----------
*.pth
*.onnx
*.pt
*.bin
*.safetensors
*.h5
*.keras
*.tflite
*.engine
*.trt
*.bpe.model  # SenseVoice 多语种 BPE 模型
*.bpe
# XTTS-v2 模型目录（约 2GB，从 ModelScope 自动下载）
Emotion-Echo-LLM/XTTS/AI-ModelScope/
Emotion-Echo-LLM/**/AI-ModelScope/
# SenseVoice 模型目录（约 200MB，从 ModelScope 自动下载）
Emotion-Echo-LLM/sensevoice-small/am.mvn
Emotion-Echo-LLM/sensevoice-small/model.pt
Emotion-Echo-LLM/sensevoice-small/chn_jpn_yue_eng_ko_spectok.bpe.model

# ---------- 工具链 / 第三方二进制 ----------
protoc-dist/
protoc.zip
*.zip
*.tar.gz

# ---------- 证书 / 密钥 ----------
*.pem
*.key
*.crt
*.p12
deploy/certs/
.env.local
.env.*.local

# ---------- 临时 / 输出 ----------
tmp/
out/
artifacts/
*.bak
*.orig

# ---------- IDE / 工具 ----------
*.code-workspace
.history/
*.tgz

# ---------- Agent / 编辑器状态 ----------
.zcode/                                  # ZCode agent session plans (transient)

# ---------- Test artifacts (Playwright / pytest reports) ----------
playwright-report/                       # Playwright HTML reporter output
test-results/                            # Playwright per-test artifact dir
.pytest_cache/                           # already covered above; explicit for clarity
__pycache__/                             # already covered above; explicit for clarity