# Emotion-Echo-Web Dockerfile.dev (Stage 26-P)
# Dev mode: `nuxt dev` HMR on :3000
# Build context: Emotion-Echo-Web/ (本目录下)
#   docker build -f Emotion-Echo-Web/Dockerfile.dev Emotion-Echo-Web

FROM node:20-alpine

ENV TZ=Asia/Shanghai \
    LANG=C.UTF-8

# 国内 npm 镜像
RUN npm config set registry https://registry.npmmirror.com

WORKDIR /app

# package*.json 利用 docker layer cache
COPY package.json package-lock.json* ./
RUN npm install

# 完整源码 (build context 是 Emotion-Echo-Web/ 目录)
COPY . ./

EXPOSE 3000

# 启动 nuxt dev 监听 0.0.0.0 让宿主可达
CMD ["npx", "nuxt", "dev", "--host", "0.0.0.0", "--port", "3000"]
