# ============================================
# Emotion-Echo 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================

# --------------------------------------------
# 基础配置 (Stage 26-Q 改进)
# 开发环境直接连 4 Go svc (绕过 APISIX 3.9 的 301 bug):
#  - user-svc        :8888
#  - chat-svc        :8890
#  - assessment-svc  :8889
#  - analytics-svc   :8904 (避开 ai-svc 8892 → 8904 是 Stage 26-P 端口映射)
# 生产环境走 APISIX :9080(Stage 27 升 3.10+ 后):
#  NUXT_PUBLIC_API_BASE_URL=https://localhost:9080/api/v1
# --------------------------------------------

NUXT_PUBLIC_API_BASE_URL=http://localhost:8888/api/v1

# 请求超时时间（毫秒）
NUXT_PUBLIC_REQUEST_TIMEOUT=10000

# --------------------------------------------
# AI 服务配置
# --------------------------------------------

# AI 流式接口地址
NUXT_PUBLIC_AI_STREAM_API=/ai/stream

# 默认使用的 LLM 模型
NUXT_PUBLIC_LLM_MODEL=gpt-4

# AI 服务 API Key（仅服务端需要）
# AI_API_KEY=your_api_key_here

# --------------------------------------------
# 应用配置
# --------------------------------------------

# 应用名称
NUXT_PUBLIC_APP_NAME=情绪回音

# 应用版本
NUXT_PUBLIC_APP_VERSION=1.0.0

# 是否开启调试模式
NUXT_PUBLIC_DEBUG=true

# --------------------------------------------
# 第三方登录配置（可选）
# --------------------------------------------

# 微信登录
# WECHAT_APP_ID=your_wechat_id_here
# WECHAT_REDIRECT_URI=http://localhost:3000/auth/wechat/callback

# QQ登录
# WECHAT_APP_ID=your_qq_id_here
# QQ_REDIRECT_URI=http://localhost:3000/auth/qq/callback

# --------------------------------------------
# 存储配置（可选）
# --------------------------------------------

# 本地存储前缀（避免多项目冲突）
NUXT_PUBLIC_STORAGE_PREFIX=emotion_echo_

# 消息缓存上限（条/会话）
NUXT_PUBLIC_MESSAGE_CACHE_LIMIT=500

# --------------------------------------------
# 调试配置（开发环境使用）
# --------------------------------------------

# 是否禁用登录拦截（true=禁用，false=启用）
# 注意：生产环境必须设置为 false 或删除此配置
NUXT_PUBLIC_DISABLE_AUTH=false

# --------------------------------------------
# 安全相关（仅服务端）
# --------------------------------------------

# JWT 密钥（生产环境必须修改）
# JWT_SECRET=your_secret_here

# 刷新 Token 有效期（天）
# REFRESH_TOKEN_EXPIRES=7

# Access Token 有效期（分钟）
# ACCESS_TOKEN_EXPIRES=15
