# Emotion-Echo 环境变量配置
# 复制此文件为 .env 并根据实际情况修改
# API Key 等敏感信息请通过环境变量或此文件配置，切勿提交到 Git

# Kimi API 密钥（必填）
EE_AI_KIMI_API_KEY=your-kimi-api-key-here

# 数据库密码（如未在 config.yaml 中配置）
EE_DATABASE_POSTGRES_PASSWORD=your-db-password

# Redis 密码（如未在 config.yaml 中配置）
EE_DATABASE_REDIS_PASSWORD=

# JWT 密钥（生产环境必须修改）
EE_JWT_SECRET=emotion-echo-secret-key-32-chars-long

# 微信 OAuth 配置
EE_OAUTH_WECHAT_APP_ID=
EE_OAUTH_WECHAT_APP_SECRET=
